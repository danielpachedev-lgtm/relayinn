# RelayInn — environment variables
# Copy to .env and fill in your values

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# App URL (local dev)
VITE_APP_URL=http://localhost:5173

# Stripe (see STRIPE_SETUP.md)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
VITE_STRIPE_PRICE_STARTER=price_xxxx
VITE_STRIPE_PRICE_PRO=price_xxxx

# Meta WhatsApp (set as Supabase edge function secrets — see WHATSAPP_SETUP.md)
# META_APP_ID, META_PHONE_NUMBER_ID, META_WHATSAPP_BUSINESS_ACCOUNT_ID,
# META_ACCESS_TOKEN, META_WEBHOOK_VERIFY_TOKEN, META_APP_SECRET
