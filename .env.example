# RelayInn — environment variables
# Copy to .env and fill in your values

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# App URL (local dev)
VITE_APP_URL=http://localhost:5173

# Stripe (see STRIPE_SETUP.md)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
VITE_STRIPE_PRICE_STARTER=price_xxxx
VITE_STRIPE_PRICE_PRO=price_xxxx

# Twilio (set as Supabase edge function secrets — see WHATSAPP_SETUP.md)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
