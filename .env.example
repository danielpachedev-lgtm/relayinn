# RelayInn — environment variables
# Copy to .env and fill in your values

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# App URL (local dev)
VITE_APP_URL=http://localhost:5173

# Stripe (see STRIPE_SETUP.md)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
VITE_STRIPE_PRICE_STARTER=price_xxxx
VITE_STRIPE_PRICE_PRO=price_xxxx

# Meta WhatsApp Embedded Signup (see WHATSAPP_SETUP.md)
VITE_META_APP_ID=3112219858968374
VITE_META_CONFIG_ID=your_config_id_here

# Meta server secrets (Supabase edge function secrets — not VITE_)
# META_APP_ID, META_APP_SECRET, META_WEBHOOK_VERIFY_TOKEN
